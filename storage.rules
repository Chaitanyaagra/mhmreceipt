rules_version = '2';

// ============================================================================
// MHMRWS Portal — Storage Security Rules
// Deploy with: firebase deploy --only storage
// (or paste into Firebase Console → Storage → Rules tab)
//
// Requires your project's "Firestore-in-Storage-rules" access (GA since 2023)
// so we can check the /admins collection without duplicating role data.
// If firestore.exists() is unavailable on your project, see the fallback
// note at the bottom of this file.
// ============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // An upload path that accepts "any bytes" is a hosting service for whoever
    // finds it: an .html file dropped into the bucket is served from the
    // society's own domain and can then be linked as if it were an official
    // document. Everything a resident uploads is either a picture or a PDF —
    // or, for the ID vault, an AES-GCM blob, which arrives as
    // application/octet-stream because that is what encryptFile() produces.
    function isImageOrPdf() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf';
    }
    function isImagePdfOrEncrypted() {
      return isImageOrPdf()
          || request.resource.contentType == 'application/octet-stream';
    }

    // Resident registration photo — owner + admins only (not public).
    match /photos/{uid}/{fileName} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Aadhaar / PAN uploads — owner + admins only, never public.
    // Files here may additionally be AES-256-GCM encrypted client-side
    // before upload (see app-common.js encryptFile()) for defense in depth.
    match /documents/{uid}/{fileName} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && isImagePdfOrEncrypted();
    }

    // UPI/bank-transfer payment screenshots — owner + admins only.
    match /paymentProofs/{uid}/{fileName} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && isImageOrPdf();
    }

    // Notice board attachments (circulars, PDFs) — public read, admin write.
    match /noticeAttachments/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 20 * 1024 * 1024
                   && isImageOrPdf();
    }

    // Committee directory photos — intentionally public.
    match /committeePhotos/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Society documents residents can download — bylaws, AGM minutes,
    // audited accounts, blank forms. Public read by design; only admins
    // publish them.
    //
    // Deliberately NOT under /documents/, which holds private Aadhaar and PAN
    // uploads: a path like documents/public/x.pdf would also match the
    // /documents/{uid}/ rule above with uid="public". That happens to be
    // harmless today, but two rules governing one file is the kind of thing
    // that turns into a leak the next time someone edits them.
    match /publicDocs/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 20 * 1024 * 1024
                   && isImageOrPdf();
    }

    // Society logo, payment QR code, downloadable forms — public read.
    match /settings/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 10 * 1024 * 1024
                   && isImageOrPdf();
    }
  }
}

// ----------------------------------------------------------------------------
// IF firestore.exists() IS NOT AVAILABLE ON YOUR PROJECT
//
// Do NOT fall back to `return isSignedIn();` here. That would make every
// resident's Aadhaar and PAN upload readable by every other resident who can
// log in — which is the single worst outcome this file exists to prevent, and
// it fails silently: nothing breaks, nothing warns you, the documents are just
// exposed.
//
// If the Firestore lookup genuinely does not work, mirror the admin UIDs into
// this file by hand instead. It is ugly and you have to edit it whenever the
// committee changes, but it fails closed:
//
//   function isAdmin() {
//     return isSignedIn() && request.auth.uid in [
//       'PASTE_SUPERADMIN_UID_HERE',
//       'PASTE_TREASURER_UID_HERE'
//     ];
//   }
//
// Firestore-in-Storage-rules has been generally available since 2023, so in
// practice the version above should just work.
// ----------------------------------------------------------------------------
